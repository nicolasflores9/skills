{
  "$schema": "https://json.schemastore.org/joomla-manifest-schema.json",
  "name": "myextension",
  "version": "2.0.0",
  "license": "GPL-2.0+",
  "description": "Ejemplo avanzado de joomla.asset.json con presets, Web Components, y dependencias complejas",
  "assets": [
    {
      "name": "jquery",
      "type": "script",
      "uri": "https://code.jquery.com/jquery-3.6.0.min.js",
      "version": "3.6.0"
    },
    {
      "name": "popper",
      "type": "script",
      "uri": "https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js",
      "version": "2.11.6"
    },
    {
      "name": "bootstrap",
      "type": "script",
      "uri": "https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js",
      "dependencies": ["popper"],
      "attributes": {
        "defer": true,
        "async": false
      },
      "version": "5.2.3"
    },
    {
      "name": "bootstrap.css",
      "type": "style",
      "uri": "https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css",
      "version": "5.2.3"
    },
    {
      "name": "jquery-validate",
      "type": "script",
      "uri": "js/jquery.validate.min.js",
      "dependencies": ["jquery"],
      "attributes": {
        "defer": true
      },
      "version": "auto"
    },
    {
      "name": "myapp.init",
      "type": "script",
      "uri": "js/app-init.js",
      "dependencies": ["jquery"],
      "attributes": {
        "defer": true
      },
      "version": "auto"
    },
    {
      "name": "myapp.module",
      "type": "script",
      "uri": "js/app-module.js",
      "dependencies": ["myapp.init"],
      "attributes": {
        "type": "module",
        "defer": true
      },
      "version": "auto"
    },
    {
      "name": "analytics",
      "type": "script",
      "uri": "https://analytics.google.com/analytics.js",
      "attributes": {
        "async": true,
        "defer": false
      },
      "version": "1.0.0"
    },
    {
      "name": "custom-loader",
      "type": "script",
      "uri": "js/custom-loader.js",
      "attributes": {
        "type": "module",
        "defer": true
      },
      "version": "auto"
    },
    {
      "name": "myapp.styles",
      "type": "style",
      "uri": "css/app.css",
      "dependencies": ["bootstrap.css"],
      "version": "auto"
    },
    {
      "name": "myapp.responsive",
      "type": "style",
      "uri": "css/responsive.css",
      "dependencies": ["myapp.styles"],
      "version": "auto"
    },
    {
      "name": "theme-dark",
      "type": "style",
      "uri": "css/theme-dark.css",
      "version": "auto"
    },
    {
      "name": "preset.frontend",
      "type": "preset",
      "uri": "",
      "dependencies": [
        "jquery#script",
        "popper#script",
        "bootstrap#script",
        "bootstrap.css#style",
        "myapp.styles#style",
        "myapp.responsive#style",
        "myapp.init#script"
      ]
    },
    {
      "name": "preset.admin",
      "type": "preset",
      "uri": "",
      "dependencies": [
        "jquery#script",
        "bootstrap#script",
        "bootstrap.css#style",
        "jquery-validate#script",
        "myapp.init#script"
      ]
    },
    {
      "name": "preset.with-analytics",
      "type": "preset",
      "uri": "",
      "dependencies": [
        "preset.frontend#preset",
        "analytics#script"
      ]
    }
  ]
}
