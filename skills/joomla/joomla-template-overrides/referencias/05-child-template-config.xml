<?xml version="1.0" encoding="utf-8"?>
<!--
    COMPLETE EXAMPLE: Child Template - Full Configuration

    Template location: /templates/cassiopeia-child/templateDetails.xml

    This file defines a child template that inherits from cassiopeia.
    It only needs to store MODIFIED files from the structure.

    CHILD STRUCTURE:
    /templates/cassiopeia-child/
    ├── html/                          (custom overrides only)
    │   └── com_content/
    │       └── article/
    │           └── default.php        (custom override)
    ├── css/
    │   └── custom.css                 (custom CSS)
    ├── templateDetails.xml            (this file)
    └── index.php                      (optional)

    ADVANTAGES:
    - Automatically inherits non-customized files
    - Parent updates are applied automatically
    - Easy maintenance: only changes are visible
    - Multiple child templates from the same parent

    JOOMLA: 5.x, 6.x
    DATE: 2024-03-06
-->

<extension type="template" client="site" method="upgrade">

    <!-- ============================================
         BASIC TEMPLATE INFORMATION
         ============================================ -->

    <name>Cassiopeia - Child Custom</name>
    <version>1.0.0</version>
    <description>Custom child template based on Cassiopeia</description>

    <!-- AUTHOR INFORMATION -->
    <author>Your Name</author>
    <authorEmail>you@email.com</authorEmail>
    <authorUrl>https://yourdomain.com</authorUrl>

    <!-- COPYRIGHT AND LICENSE -->
    <copyright>Copyright 2024 Your Name. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>

    <!-- DOCUMENTATION URL -->
    <url>https://yourdomain.com/documentation</url>

    <!-- ============================================
         PARENT TEMPLATE CONFIGURATION
         ============================================ -->

    <!-- PARENT TEMPLATE: template it inherits from -->
    <parent>cassiopeia</parent>

    <!-- ============================================
         CHILD TEMPLATE FILES
         ============================================ -->

    <files>
        <!-- FOLDERS: include only if they contain modifications -->
        <folder>html</folder>
        <folder>css</folder>

        <!-- FILES -->
        <filename>templateDetails.xml</filename>
        <filename>index.php</filename>
        <filename>README.md</filename>
    </files>

    <!-- ============================================
         MEDIA (RESOURCES: IMAGES, FONTS, ETC.)
         ============================================ -->

    <media destination="templates/cassiopeia-child" folder="media">
        <folder>images</folder>
        <folder>fonts</folder>
    </media>

    <!-- ============================================
         MODULE POSITIONS
         ============================================ -->

    <positions>
        <!-- Inherited from parent: you don't need to redefine them -->
        <!-- But if you do, you REPLACE the parent configuration -->

        <position>header</position>
        <position>nav</position>
        <position>sidebar-left</position>
        <position>sidebar-right</position>
        <position>main</position>
        <position>footer</position>
    </positions>

    <!-- ============================================
         CONFIGURABLE PARAMETERS
         ============================================ -->

    <config>
        <fields name="params">
            <!-- FIELDSET: BASIC -->
            <fieldset name="basic" label="Basic Configuration">

                <!-- Logo -->
                <field name="logo" type="media" label="Logo"
                       description="Select logo file">
                </field>

                <!-- Text logo -->
                <field name="logo_text" type="text" label="Logo Text"
                       default="My Site">
                </field>

                <!-- Colors -->
                <field name="primary_color" type="color" label="Primary Color"
                       default="#007bff">
                </field>

                <!-- Typography -->
                <field name="font_family" type="list" label="Font Family"
                       default="sans-serif">
                    <option value="sans-serif">Sans Serif</option>
                    <option value="serif">Serif</option>
                    <option value="monospace">Monospace</option>
                </field>

            </fieldset>

            <!-- FIELDSET: LAYOUT -->
            <fieldset name="layout" label="Layout">

                <!-- Site width -->
                <field name="site_width" type="list" label="Site Width"
                       default="wide">
                    <option value="narrow">Narrow (900px)</option>
                    <option value="standard">Standard (1200px)</option>
                    <option value="wide">Wide (1400px)</option>
                </field>

                <!-- Sidebar -->
                <field name="show_sidebar" type="radio" label="Show Sidebar"
                       default="1" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

            </fieldset>

            <!-- FIELDSET: COMPONENTS -->
            <fieldset name="components" label="Components">

                <!-- Show breadcrumbs -->
                <field name="show_breadcrumbs" type="radio" label="Show Breadcrumbs"
                       default="1" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

                <!-- Show page title -->
                <field name="show_page_title" type="radio" label="Show Page Title"
                       default="1" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

            </fieldset>

            <!-- FIELDSET: ADVANCED -->
            <fieldset name="advanced" label="Advanced">

                <!-- Enable cache -->
                <field name="enable_cache" type="radio" label="Enable Cache"
                       default="1" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

                <!-- Enable CSS compression -->
                <field name="compress_css" type="radio" label="Compress CSS"
                       default="0" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

                <!-- Enable JS compression -->
                <field name="compress_js" type="radio" label="Compress JavaScript"
                       default="0" class="btn-group btn-group-yesno">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </field>

            </fieldset>

        </fields>
    </config>

    <!-- ============================================
         CSS VARIABLES
         ============================================ -->

    <variable name="primary_color">
        <value>#007bff</value>
    </variable>

    <variable name="secondary_color">
        <value>#6c757d</value>
    </variable>

</extension>

<!--
    ============================================
    IMPLEMENTATION NOTES
    ============================================

    1. PARENT: Specifies 'cassiopeia' as parent
       Joomla automatically inherits its files

    2. FILES: Only include folders with changes
       html/    → only if there are overrides
       css/     → only if there is custom CSS

    3. POSITIONS: Inherited from parent
       Redefine only if you change the structure

    4. PARAMETERS: Configurable from the backend
       Users can customize without touching code

    5. MEDIA: Resources like images, fonts, etc.
       destination: where they are copied during installation

    6. CSS VARIABLES: For dynamic themes
       Use in parent's less/scss

    ============================================
    MINIMUM CHILD TEMPLATE STRUCTURE
    ============================================

    If you ONLY customize one file:

    /templates/cassiopeia-child/
    ├── html/
    │   └── com_content/
    │       └── article/
    │           └── default.php     (your override)
    └── templateDetails.xml

    That is sufficient. Everything else is inherited from parent.

    ============================================
    AUTOMATIC INHERITANCE
    ============================================

    Joomla looks for files in this order:
    1. /templates/cassiopeia-child/html/...     (child)
    2. /templates/cassiopeia/html/...           (parent)
    3. /components/.../views/.../tmpl/...       (core)

    If not in child, uses parent.
    If not in parent, uses core.

    ============================================
    UPDATING PARENT TEMPLATE
    ============================================

    If the parent cassiopeia is updated:
    - Child template inherits changes automatically
    - Child overrides are not affected
    - New files in parent are inherited

    To verify changes:
    1. Go to Extensions > Templates
    2. Click on child template
    3. Look for "Inherited Files" (if available)

    ============================================
    CREATING MULTIPLE CHILD TEMPLATES
    ============================================

    You can create several child templates from the same parent:

    /templates/cassiopeia-child-1/     (light theme)
    /templates/cassiopeia-child-2/     (dark theme)
    /templates/cassiopeia-child-3/     (special design)

    Each one is independent:
    - Same overrides inherited from parent
    - Different custom CSS in each
    - Assign to different menus

    ============================================
    CHILD TEMPLATE MAINTENANCE
    ============================================

    Version control (GIT):
    .gitignore should ignore:
    - cache/
    - tmp/
    - logs/

    Changes to track:
    - html/           (all overrides)
    - css/            (all custom CSS)
    - templateDetails.xml
    - index.php (if modified)

    ============================================
-->
